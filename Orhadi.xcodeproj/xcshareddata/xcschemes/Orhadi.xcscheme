               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "2804F4D72D92275700649FD0"
                     BuildableName = "Orhadi.app"
                     BlueprintName = "Orhadi"
                     ReferencedContainer = "container:Orhadi.xcodeproj">
